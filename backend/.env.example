# Backend server
HOST=0.0.0.0
PORT=8000

# Frontend origin for CORS (comma separated)
CORS_ORIGINS=http://localhost:5173

# Pick one: xgboost or random_forest
DEFAULT_MODEL=random_forest

# OpenAI compatible vision extraction
OPENAI_API_KEY=your-azure-openai-api-key
OPENAI_BASE_URL=https://amanm10000-0694-resource.openai.azure.com/openai/v1
OPENAI_MODEL=gpt-5.3-chat

# Upload limits
MAX_UPLOAD_MB=8
